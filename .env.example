# ============================================================
# FarmBalance - Environment Variables
# 용도: docker-compose 및 로컬 개발에서 사용하는 환경 변수 템플릿
# 사용: 이 파일을 복사하여 .env로 만든 뒤 값을 수정하세요.
#       cp .env.example .env
# ============================================================

# ── Database (PostgreSQL 16) ──
DB_USERNAME=farm
DB_PASSWORD=farm_secret_password

# ── Security (JWT + BCrypt) ──
JWT_SECRET=your_jwt_secret_key_here_change_me

# ── External APIs (Backend) ──
KAKAO_REST_API_KEY=your_kakao_rest_key_here
KMA_API_KEY=your_meteorological_agency_key_here
SOIL_API_KEY=your_soil_exam_key_here
KOSIS_API_KEY=your_kosis_stats_key_here
NONGSARO_API_KEY=your_nongsaro_key_here

# ── AI (Gemini API) ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Kakao Map API (Frontend) ──
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_key_here
