# ============================================================
# FarmBalance - Environment Variables
# 용도: docker-compose 및 로컬 개발에서 사용하는 환경 변수 템플릿
# 사용: 이 파일을 복사하여 .env.local로 만든 뒤 값을 수정하세요.
#       cp .env.example .env.local
# ============================================================

# ── Database (PostgreSQL 16) ──
DB_USERNAME=farm
DB_PASSWORD=your_db_password_here
DB_URL=jdbc:postgresql://localhost:5151/farm_db

# ── Security (JWT + BCrypt) ──
JWT_SECRET=your_jwt_secret_key_here_change_me

# ── External APIs (Backend + AI 공용) ──
KAKAO_REST_API_KEY=your_kakao_rest_key_here
KMA_API_KEY=your_meteorological_agency_key_here
SOIL_API_KEY=your_soil_exam_key_here
KOSIS_API_KEY=your_kosis_stats_key_here
NONGSARO_API_KEY=your_nongsaro_key_here

# ── Policy (행정안전부 공공서비스 혜택 정보 - gov24 v3) ──
GOV24_API_KEY=your_gov24_key_here

# ── AI (LLM) ──
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── OAuth2 ──
KAKAO_CLIENT_ID=your_kakao_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── AI 서버 설정 ──
SCHEDULER_ENABLED=false
AI_SERVER_PORT=8000
