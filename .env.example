# ============================================================
# FarmBalance - Environment Variables
# 용도: docker-compose 및 로컬 개발에서 사용하는 환경 변수 템플릿
# 사용: 이 파일을 복사하여 .env.local로 만든 뒤 값을 수정하세요.
#       cp .env.example .env.local
# ============================================================

# ── Database (PostgreSQL 16) ──
DB_USERNAME=farm
DB_PASSWORD=your_db_password_here
DB_URL=jdbc:postgresql://localhost:5151/farm_db

# ── Security (JWT + BCrypt) ──
JWT_SECRET=your_jwt_secret_key_here_change_me

# ── External APIs (Backend + AI 공용) ──
KAKAO_REST_API_KEY=your_kakao_rest_key_here
KMA_API_KEY=your_meteorological_agency_key_here
SOIL_API_KEY=your_soil_exam_key_here
NONGSARO_API_KEY_DEFAULT=your_nongsaro_default_key_here
NONGSARO_API_KEY_CROP_EBOOK=your_nongsaro_crop_ebook_key_here
KOSIS_API_KEY=your_kosis_stats_key_here
NONGSARO_API_KEY=your_nongsaro_key_here

# ── Policy (행정안전부 공공서비스 혜택 정보 - gov24 v3) ──
GOV24_API_KEY=your_gov24_key_here

# ── AI (LLM) ──
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── OAuth2 ──
KAKAO_CLIENT_ID=your_kakao_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── KAMIS (농산물 유통공판장 가격 API) ──
KAMIS_API_URL=https://www.kamis.or.kr/service/price/xml.do
KAMIS_CERT_KEY=your_kamis_cert_key_here
KAMIS_CERT_ID=your_kamis_cert_id_here

# ── AI 서버 설정 ──
SCHEDULER_ENABLED=false
AI_SERVER_PORT=8000
AI_SERVER_URL=http://localhost:8000

# ── BFF → AI 서버 내부 인증 키 (STT/Voice 기능) ──
# Next.js BFF Route Handler → AI FastAPI 서버 호출 시 사용하는 공유 시크릿.
# ai/.env 의 AI_INTERNAL_SECRET_KEY 와 반드시 동일한 값으로 설정하세요.
# openssl rand -hex 32  로 생성 권장
AI_INTERNAL_SECRET_KEY=change-me-to-a-strong-random-secret

# ── Email (SMTP — Gmail) ──
# Gmail 사용 시: Google 계정 → 보안 → 앱 비밀번호 생성 필요
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_app_password_here

# ── Frontend (NEXT_PUBLIC 접두사 = 클라이언트 번들에 포함) ──
NEXT_PUBLIC_KAKAO_MAP_JS_KEY=your_kakao_map_js_key_here
NEXT_PUBLIC_PORTONE_STORE_ID=your_portone_store_id_here
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=your_portone_channel_key_here

# ── Firebase (FCM 푸시 알림) ──
# Firebase Console → 프로젝트 설정 → 일반 → 웹 앱에서 발급
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here
# Firebase Console → 프로젝트 설정 → Cloud Messaging → 웹 푸시 인증서에서 발급
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here

# Firebase Admin SDK (Backend FCM 푸시 발송용)
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성 → JSON 다운로드
# 다운받은 JSON 파일을 Base64로 인코딩한 한 줄 문자열을 입력:
#   macOS:  base64 -i firebase-adminsdk.json | tr -d '\n'
#   Linux:  base64 -w 0 firebase-adminsdk.json
FIREBASE_CREDENTIALS_BASE64=your_firebase_adminsdk_base64_here
