# ═══ LLM Provider 설정 ═══
# gemini | groq | bedrock
LLM_PROVIDER=gemini

# ── Gemini ──
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── Groq (추후) ──
# GROQ_API_KEY=your-groq-api-key-here
# GROQ_MODEL=llama-3.1-70b-versatile

# ── AWS Bedrock (추후) ──
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# ═══ 서버 설정 ═══
AI_SERVER_PORT=8000
DEBUG=false

# ── BFF → AI 서버 내부 인증 키 ──
# Next.js BFF Route Handler가 AI 서버 호출 시 X-AI-Internal-Key 헤더에 첨부하는 시크릿.
# 루트 .env.example 의 AI_INTERNAL_SECRET_KEY 와 동일한 값이어야 합니다.
AI_INTERNAL_SECRET_KEY=change-me-to-a-strong-random-secret
